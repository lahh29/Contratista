
{
  "entities": {
    "Contractor": {
      "title": "Contractor",
      "description": "Details of a contractor and their compliance status.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the contractor" },
        "company": { "type": "string", "description": "Company the contractor belongs to" },
        "phone": { "type": "string", "description": "Contact phone number" },
        "suaStatus": { 
          "type": "string", 
          "enum": ["Active", "Expired", "Pending"],
          "description": "Current status of the SUA insurance"
        },
        "suaExpiration": { "type": "string", "format": "date", "description": "Expiration date of the SUA" },
        "policyNumber": { "type": "string", "description": "Insurance policy number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "company", "suaStatus"]
    },
    "Visit": {
      "title": "Visit",
      "description": "A record of a work visit on-site.",
      "type": "object",
      "properties": {
        "company": { "type": "string" },
        "responsible": { "type": "string" },
        "phone": { "type": "string" },
        "suaCode": { "type": "string" },
        "personnelCount": { "type": "number" },
        "personnelList": { "type": "string" },
        "area": { "type": "string" },
        "manager": { "type": "string" },
        "activity": { "type": "string" },
        "vehicle": { "type": "string" },
        "entryTime": { "type": "string", "format": "date-time" },
        "exitTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Active", "Finished", "Pending"] }
      },
      "required": ["company", "responsible", "area", "status"]
    },
    "AccessLog": {
      "title": "Access Log",
      "description": "A record of an entry or exit event.",
      "type": "object",
      "properties": {
        "contractorId": { "type": "string" },
        "contractorName": { "type": "string" },
        "action": { "type": "string", "enum": ["ENTRY", "EXIT"] },
        "area": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["VERIFIED", "DENIED"] }
      },
      "required": ["contractorId", "action", "timestamp", "status"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/contractors/{contractorId}": {
      "schema": "Contractor",
      "description": "Collection of registered contractors."
    },
    "/visits/{visitId}": {
      "schema": "Visit",
      "description": "Records of on-site visits."
    },
    "/accessLogs/{logId}": {
      "schema": "AccessLog",
      "description": "Historical log of access events."
    }
  }
}
