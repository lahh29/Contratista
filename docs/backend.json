{
  "entities": {
    "Company": {
      "title": "Company",
      "description": "Details of a contracting company and its compliance status.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contact": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Blocked"] },
        "sua": {
          "type": "object",
          "properties": {
            "number": { "type": "string" },
            "validUntil": { "type": "string", "format": "date" },
            "status": { "type": "string", "enum": ["Valid", "Expired", "Pending"] }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    },
    "Visit": {
      "title": "Visit",
      "description": "Main operational record for a work visit.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "companyName": { "type": "string" },
        "areaId": { "type": "string" },
        "areaName": { "type": "string" },
        "supervisorId": { "type": "string" },
        "personnelCount": { "type": "number" },
        "activity": { "type": "string" },
        "qrCode": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Active", "Completed", "Cancelled"] },
        "entryTime": { "type": "string", "format": "date-time" },
        "exitTime": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "areaId", "status"]
    },
    "Area": {
      "title": "Area",
      "description": "Physical area or department configuration.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "supervisorId": { "type": "string" },
        "maxCapacity": { "type": "number" }
      },
      "required": ["name"]
    },
    "PersonnelEntry": {
      "title": "Personnel Entry",
      "description": "Individual tracking for each person in a visit.",
      "type": "object",
      "properties": {
        "visitId": { "type": "string" },
        "name": { "type": "string" },
        "idNumber": { "type": "string" },
        "photo": { "type": "string", "description": "Base64 or URL" },
        "status": { "type": "string", "enum": ["Inside", "Outside"] },
        "entryTime": { "type": "string", "format": "date-time" },
        "exitTime": { "type": "string", "format": "date-time" }
      },
      "required": ["visitId", "name", "status"]
    },
    "AccessLog": {
      "title": "Access Log",
      "description": "Security logs for entry and exit events.",
      "type": "object",
      "properties": {
        "contractorId": { "type": "string" },
        "contractorName": { "type": "string" },
        "action": { "type": "string", "enum": ["ENTRY", "EXIT"] },
        "area": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["contractorId", "action", "timestamp"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/companies/{companyId}": {
      "schema": "Company",
      "description": "Registered companies."
    },
    "/areas/{areaId}": {
      "schema": "Area",
      "description": "Configured work areas."
    },
    "/visits/{visitId}": {
      "schema": "Visit",
      "description": "Main visit records."
    },
    "/visits/{visitId}/personnel_entries/{entryId}": {
      "schema": "PersonnelEntry",
      "description": "Individual access events per visit."
    },
    "/accessLogs/{logId}": {
      "schema": "AccessLog",
      "description": "Security access history logs."
    }
  }
}