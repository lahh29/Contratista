rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas para la colección de Empresas
    match /companies/{companyId} {
      allow read, write: if request.auth != null;
    }
    
    // Reglas para la colección de Áreas
    match /areas/{areaId} {
      allow read, write: if request.auth != null;
    }
    
    // Reglas para la colección de Visitas y sus subcolecciones
    match /visits/{visitId} {
      allow read, write: if request.auth != null;
      
      match /personnel_entries/{entryId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Reglas para la colección de Logs de Acceso
    match /accessLogs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Regla global por defecto para evitar errores en otras colecciones durante el desarrollo
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}