rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permitir lectura y escritura en todas las colecciones para usuarios autenticados
    // Se añade este comentario para forzar el despliegue de las reglas.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}