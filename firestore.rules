rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isAuthed() {
      return request.auth != null;
    }

    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin()      { return isAuthed() && myRole() == 'admin';      }
    function isGuard()      { return isAuthed() && myRole() == 'guard';      }
    function isContractor() { return isAuthed() && myRole() == 'contractor'; }
    function isSeguridad()  { return isAuthed() && myRole() == 'seguridad';  }
    function isLogistica()  { return isAuthed() && myRole() == 'logistica';  }

    function myCompanyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Cada usuario lee su propio doc; el admin lee todos
      allow read: if isAuthed() && (request.auth.uid == userId || isAdmin());
      // Solo el admin puede cambiar roles / empresa asignada
      allow write: if isAdmin();
      // El propio usuario puede crear su documento inicial (registro)
      allow create: if isAuthed() && request.auth.uid == userId;
      // El usuario puede actualizar lastLoginAt y companyId en su propio doc
      allow update: if isAuthed() && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['lastLoginAt', 'companyId']);

      // FCM tokens — el usuario gestiona los suyos
      match /fcmTokens/{tokenId} {
        allow read, write: if isAuthed() && request.auth.uid == userId;
      }
    }

    // ── Companies ──────────────────────────────────────────────────────────────
    match /companies/{companyId} {
      // Admin, guardia, seguridad y logística: lectura general
      // Contratista: solo su propia empresa
      allow read: if isAdmin() || isGuard() || isSeguridad() || isLogistica() ||
                    (isContractor() && myCompanyId() == companyId);
      // Admin: control total
      // Seguridad: solo proveedores
      // Logística: solo clientes
      allow create: if isAdmin() ||
                      (isSeguridad() && request.resource.data.type == 'proveedor') ||
                      (isLogistica() && request.resource.data.type == 'cliente');
      allow update: if isAdmin() ||
                      (isSeguridad() && resource.data.type == 'proveedor') ||
                      (isLogistica() && resource.data.type == 'cliente');
      allow delete: if isAdmin();
    }

    // ── Visits ─────────────────────────────────────────────────────────────────
    match /visits/{visitId} {
      // Admin: todo
      // Guardia, seguridad, logística: leer todo
      // Contratista: solo visitas de su empresa
      allow read: if isAdmin() || isGuard() || isSeguridad() || isLogistica() ||
                    (isContractor() && resource.data.companyId == myCompanyId());
      // Guardia: crea/actualiza cualquier visita (scanner)
      // Seguridad: solo visitas de proveedores
      // Logística: solo visitas de clientes
      allow create: if isAdmin() || isGuard() ||
                      (isSeguridad() && request.resource.data.companyType == 'proveedor') ||
                      (isLogistica() && request.resource.data.companyType == 'cliente');
      allow update: if isAdmin() || isGuard() ||
                      (isSeguridad() && resource.data.companyType == 'proveedor') ||
                      (isLogistica() && resource.data.companyType == 'cliente');
      allow delete: if isAdmin();
    }

    // ── Areas ──────────────────────────────────────────────────────────────────
    match /areas/{areaId} {
      // Todos los usuarios autenticados necesitan leer las áreas (wizard, escáner, portal)
      allow read: if isAuthed();
      // Solo admin configura áreas
      allow write: if isAdmin();
    }

    // ── Supervisors ────────────────────────────────────────────────────────────
    match /supervisors/{supervisorId} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // ── Notifications (FCM / banners) ──────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // ── Audit Log ───────────────────────────────────────────────────────────────
    match /auditLog/{entryId} {
      // Solo el admin puede leer; escritura solo via Admin SDK (server-side)
      allow read: if isAdmin();
      allow write: if false;
    }

  }
}
