rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla global para desarrollo: Permitir todo a usuarios autenticados
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Reglas explícitas para mayor claridad y seguridad futura
    match /companies/{companyId} {
      allow read, write: if request.auth != null;
    }
    
    match /areas/{areaId} {
      allow read, write: if request.auth != null;
    }
    
    match /visits/{visitId} {
      allow read, write: if request.auth != null;
      
      match /personnel_entries/{entryId} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /accessLogs/{logId} {
      allow read, write: if request.auth != null;
    }
  }
}